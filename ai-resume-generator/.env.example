# ==========================================
# AI Resume Generator - Environmental Variables
# ==========================================

# -- Server Configuration --
PORT=5000
NODE_ENV=production

# -- Security --
# Comma-separated list of allowed origins for CORS.
ALLOWED_ORIGINS=http://localhost

# -- Service URLs --
PYTHON_BACKEND_URL=http://python-backend:8000

# -- AI Model Access (LM Studio Base) --
LM_STUDIO_URL=http://host.docker.internal:1234/v1/chat/completions
LM_STUDIO_MODEL=mistralai/mistral-7b-instruct-v0.3

# -- Optional: AI Tuning --
# LM_STUDIO_TIMEOUT=60
# LM_STUDIO_MAX_TOKENS=200
# LM_STUDIO_TEMPERATURE=0.4
